{
  "rewrites": [
    {
      "source": "/vworld-api/address",
      "destination": "https://api.vworld.kr/req/address"
    },
    {
      "source": "/vworld-api/data",
      "destination": "https://api.vworld.kr/req/data"
    },
    {
      "source": "/vworld-api/wmts/:path*",
      "destination": "https://api.vworld.kr/req/wmts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
